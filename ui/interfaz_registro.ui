   <string notr="true">
QWidget{
	background-color: #111720

}

/* INPUTS */
QLineEdit {
    background-color: #3c3f41;
    border: 2px solid #555;
    border-radius: 10px;
    padding: 5px;
    color: white;
}

QLineEdit:focus {
    border: 2px solid #4da6ff;
}

/* BOTONES */
QPushButton {
    background-color: #4a4a4a;
    border: none;
    border-radius: 10px;
    padding: 8px;
    color: white;
    font-weight: bold;
}

/* EFECTO HOVER */
QPushButton:hover {
    background-color: #5c5c5c;
}

/* CUANDO SE APRIETA */
QPushButton:pressed {
    background-color: #2f2f2f;
}</string>
